# =============================================================================
# CoderHelm Jira Forge App — Environment Notes
# =============================================================================
# The Forge app runs on Atlassian's infrastructure, so traditional .env files
# are not used at runtime. Configuration is stored in Forge Storage via the
# admin page (Apps → Coderhelm Settings).
#
# During local development with `forge tunnel`, the app connects to the
# production CoderHelm API by default. To point at a local gateway instead,
# update the fetch URL in src/index.js:
#
#   CODERHELM_API_URL=http://localhost:9000
#
# Note: Forge's egress allowlist in manifest.yml must include the URL you
# use. For tunnelling, the Forge CLI proxies requests so localhost works
# through the tunnel without manifest changes.
# =============================================================================

# The URL the Forge functions use to call the CoderHelm API.
# Default (production): https://api.coderhelm.com
# Local development:    http://localhost:9000
CODERHELM_API_URL=https://api.coderhelm.com
