# =============================================================================
# CoderHelm — Environment Variables
# =============================================================================
# Copy to .env and fill in real values.
# Variables are grouped by the service that reads them.
# See README.md for full descriptions and defaults.
# =============================================================================

# ---------------------  Shared (gateway + worker)  ---------------------------
STAGE=dev
TABLE_NAME=coderhelm-dev-main
RUNS_TABLE_NAME=coderhelm-dev-runs
ANALYTICS_TABLE_NAME=coderhelm-dev-analytics
BUCKET_NAME=coderhelm-dev-storage
SECRETS_NAME=coderhelm/dev/secrets
MODEL_ID=us.anthropic.claude-sonnet-4-6
SES_FROM_ADDRESS=noreply@coderhelm.com
SES_TEMPLATE_PREFIX=coderhelm-dev
RUST_LOG=info

# ---------------------  Gateway-only  ----------------------------------------
TICKET_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/coderhelm-dev-tickets
CI_FIX_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/coderhelm-dev-ci-fix
FEEDBACK_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/coderhelm-dev-feedback
DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/coderhelm-dev-dlq
INVOICE_BUCKET_NAME=coderhelm-dev-invoices

# ---------------------  Worker-only  -----------------------------------------
# (The worker reads SECRETS_NAME from Config::from_env() directly;
#  see services/worker/src/models.rs)
